{
  "name": "ai-knowledge-graph",
  "private": true,
  "version": "0.5.0",
  "type": "module",
  "description": "可视化的 AI 知识图谱 — 力导向图展示 AI 领域核心概念、架构与技术之间的关系",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "lint": "tsc -b --noEmit",
    "validate": "tsx scripts/validate-graph.ts",
    "check-coverage": "tsx scripts/check-coverage.ts",
    "check-coverage:ai": "tsx scripts/check-coverage.ts ai",
    "check-coverage:pm": "tsx scripts/check-coverage.ts pm",
    "check-coverage:black-myth": "tsx scripts/check-coverage.ts black-myth"
  },
  "dependencies": {
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "react-force-graph-2d": "^1.27.0"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.1.0",
    "@types/react": "^19.1.0",
    "@types/react-dom": "^19.1.0",
    "@vitejs/plugin-react": "^4.4.0",
    "tailwindcss": "^4.1.0",
    "tsx": "^4.22.4",
    "typescript": "^5.8.0",
    "vite": "^6.3.0"
  }
}
